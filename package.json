{
  "name": "mythes-deloron-game",
  "version": "0.1.0",
  "private": true,
  "description": "Environnement local de développement de Mythes d’Eloron.",
  "type": "module",
  "scripts": {
    "dev": "node tools/dev-server.mjs",
    "verify": "node tools/verify-workspace.mjs",
    "smoke": "node tools/smoke-test.mjs",
    "check": "node tools/verify-workspace.mjs && node tools/smoke-test.mjs",
    "test:browser": "playwright test",
    "test:browser:infra": "playwright test tests/browser/infrastructure.spec.mjs",
    "test:browser:characterization": "playwright test tests/browser/characterization.spec.mjs",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "test:browser:report": "playwright show-report"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
