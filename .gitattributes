# Détection générale des fichiers texte.
* text=auto

# Fichiers texte du projet.
*.html text eol=lf
*.htm text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts Windows.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Formats binaires.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.wav binary
*.mp3 binary
*.ogg binary
*.flac binary
*.mp4 binary
*.webm binary
*.pdf binary
*.xlsx binary
*.xls binary
*.ods binary
*.zip binary
*.7z binary
*.rar binary
